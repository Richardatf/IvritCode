{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ivritcode.org/spec/ivritcode-exchange-0.1.schema.json",
  "title": "IvritCode–Quantum Etz Chaim Exchange 0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "source",
    "sourceHash",
    "initialState",
    "finalState",
    "hiddenKey",
    "patternShape",
    "returningLetters",
    "gates"
  ],
  "properties": {
    "schemaVersion": { "const": "ivritcode-exchange-0.1" },
    "source": { "type": "string", "maxLength": 2048 },
    "sourceHash": { "type": "string", "minLength": 1 },
    "initialState": { "$ref": "#/$defs/registerState" },
    "finalState": { "$ref": "#/$defs/registerState" },
    "hiddenKey": { "type": "string" },
    "patternShape": { "type": "string" },
    "returningLetters": {
      "type": "array",
      "items": { "type": "string" }
    },
    "gates": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "registerState": {
      "type": "array",
      "minItems": 23,
      "maxItems": 23,
      "items": { "type": "integer", "minimum": 0, "maximum": 21 }
    }
  }
}
