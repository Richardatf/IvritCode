{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "dist-types",
    "jsx": "react-jsx",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": false,
    "noEmit": true,
    "composite": true
  },
  "references": [
    { "path": "../../packages/qec-spec" },
    { "path": "../../packages/ivrit-compiler" },
    { "path": "../../packages/path-router" },
    { "path": "../../packages/gates-231" },
    { "path": "../../packages/qec-core" },
    { "path": "../../packages/core" },
    { "path": "../../packages/analysis" },
    { "path": "../../packages/lexicon" }
  ],
  "include": ["src/**/*.ts", "src/**/*.tsx", "vite.config.ts"]
}
