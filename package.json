{
  "name": "ivritcode",
  "version": "1.0.0",
  "private": true,
  "description": "IvritCode — a deterministic Hebrew symbolic computing language",
  "homepage": "https://ivritcode.org",
  "repository": "github:Richardatf/IvritCode",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "openai": "^6.16.0"
  },
  "scripts": {
    "dev": "npm run dev -w @ivritcode/web",
    "sync:spec": "node scripts/sync-spec.mjs",
    "build": "npm run sync:spec && npm run build --workspaces --if-present",
    "test": "npm run build && vitest run --coverage.enabled=false",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "typecheck": "tsc -b --pretty false",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "cli": "npm run build -w @ivritcode/cli && node apps/cli/dist/index.js",
    "clean": "node scripts/clean.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.19.7",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^16.5.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.53.1",
    "vitest": "^4.1.0"
  }
}
